# =============================================================
# Discord ↔ GitHub Sync Bot — Configuration
# =============================================================

# --- Required: Discord ---
# Bot token — https://discord.com/developers/applications
DISCORD_TOKEN=

# Forum channel ID (Developer Mode → right-click channel → Copy ID)
DISCORD_CHANNEL_ID=

# --- Required: GitHub ---
# Fine-grained PAT with Issues: Read & Write on the target repo
# https://github.com/settings/tokens?type=beta
GITHUB_ACCESS_TOKEN=
GITHUB_USERNAME=
GITHUB_REPOSITORY=

# --- Optional: Webhook server ---
PORT=5000

# --- Recommended: Webhook signature verification ---
# Prevents unauthorized actors from sending fake webhook events.
# Generate: openssl rand -hex 32
# Then add the same value to your GitHub webhook's "Secret" field.
# Without this, the bot will warn at startup and accept all requests.
GITHUB_WEBHOOK_SECRET=

# --- Optional: Cloudflare R2 image re-hosting ---
# Discord CDN URLs expire after ~7 days, breaking images in GitHub issues.
# Set all four to re-host attachments permanently to your own CDN.
# Without these, Discord attachment URLs are used as-is.
R2_BUCKET=
R2_CDN_BASE_URL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
