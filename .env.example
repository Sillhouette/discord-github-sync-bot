# Discord Configuration
# Get token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord forum channel ID where bot listens
# Enable Developer Mode in Discord → Right-click channel → Copy ID
DISCORD_CHANNEL_ID=your_forum_channel_id_here

# GitHub Configuration
# Generate fine-grained PAT: https://github.com/settings/tokens?type=beta
# Permissions: Repository access → osrs-companion → Issues (Read and write)
GITHUB_ACCESS_TOKEN=your_github_pat_here

# GitHub repository details
GITHUB_USERNAME=raustin
GITHUB_REPOSITORY=osrs-companion

# Webhook Server Port
PORT=5000
